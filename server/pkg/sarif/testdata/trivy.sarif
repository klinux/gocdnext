{
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Trivy",
          "rules": [
            {
              "id": "CVE-2023-1234",
              "properties": { "security-severity": "9.8" }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "CVE-2023-1234",
          "level": "error",
          "message": { "text": "openssl: critical buffer overflow" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "go.sum" },
                "region": { "startLine": 1 }
              }
            }
          ],
          "properties": { "security-severity": "9.8" }
        }
      ]
    }
  ]
}
