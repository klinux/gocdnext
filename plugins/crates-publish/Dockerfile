# gocdnext/crates-publish — publish a crate to crates.io (or an
# alternate registry).
#
# Contract:
#   CARGO_REGISTRY_TOKEN (required)  via the job's `secrets:` —
#                                    cargo reads it natively from
#                                    env, never argv.
#   PLUGIN_DIR           (optional)  crate dir, default ".".
#   PLUGIN_DRY_RUN       (optional)  cargo publish --dry-run
#                                    (packages + verifies the build,
#                                    uploads nothing, no token).
#   PLUGIN_ALLOW_DIRTY   (optional)  pass --allow-dirty (workspace
#                                    files generated by earlier jobs).
FROM rust:1-alpine

RUN apk add --no-cache git musl-dev

COPY entrypoint.sh /usr/local/bin/gocdnext-crates-publish
RUN chmod +x /usr/local/bin/gocdnext-crates-publish

WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/gocdnext-crates-publish"]
