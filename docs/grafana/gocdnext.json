        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"axisLabel": "seconds", "drawStyle": "line", "fillOpacity": 0, "gradientMode": "none", "lineInterpolation": "linear", "lineWidth": 2, "pointSize": 5, "showPoints": "never", "spanNulls": false},
